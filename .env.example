# ── Rentix Frontend ─────────────────────────────────────────────
# Copiar a .env.local para desarrollo (*.local está en .gitignore).
# En Render / Azure Static, definir como variables de entorno del build.

# URL del Middleware Interno (auth, reservas, facturas) — sin /interno
VITE_API_BASE_URL=https://rentix-middleware-interno-api-c0f5g8djhnbkejcs.chilecentral-01.azurewebsites.net/api/v1

# URL base para endpoints internos (catálogo, clientes, localizaciones, seguridad)
# Si se omite, se deriva automáticamente de VITE_API_BASE_URL + /interno
VITE_INTERNOS_BASE_URL=https://rentix-middleware-interno-api-c0f5g8djhnbkejcs.chilecentral-01.azurewebsites.net/api/v1/interno

# Cloudinary (subida de imágenes de vehículos)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Imagen de fondo del hero (Home). Sube la imagen a Cloudinary y pega la URL aquí.
# Si se deja vacío, se usa el gradiente por defecto.
VITE_HERO_BG_IMAGE=
